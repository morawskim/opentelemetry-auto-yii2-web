{
  "name": "mmo/opentelemetry-auto-yii2-web",
  "description": "OpenTelemetry auto-instrumentation for Yii2 web app",
  "keywords": ["opentelemetry", "otel", "open-telemetry", "tracing", "yii2", "instrumentation"],
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.2",
    "ext-opentelemetry": "*",
    "open-telemetry/api": "^1.0",
    "open-telemetry/sem-conv": "^1.36"
  },
  "require-dev": {
    "open-telemetry/sdk": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Mmo\\Instrumentation\\Yii2\\": "src/"
    },
    "files": [
      "_register.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Mmo\\Tests\\Instrumentation\\Yii2\\": "tests/"
    }
  }
}
